# =============================================================================
# MLB Predictor Engine — Backend Environment Variables
#
# HOW TO USE:
#   Local dev : Copy this file → rename to `.env` → fill in your values.
#   Render    : Add these as "Environment Variables" in your service dashboard.
#               Do NOT upload this file — set each key/value manually there.
# =============================================================================

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
# Options: development | production
APP_ENV=development

# ---------------------------------------------------------------------------
# API Server (Render sets PORT automatically — do not override on Render)
# ---------------------------------------------------------------------------
PORT=8000

# ---------------------------------------------------------------------------
# CORS — Allowed Frontend Origins
# In production set this to your Vercel domain.
# Multiple origins: comma-separated "https://foo.vercel.app,https://bar.com"
# Use "*" only during local development.
# ---------------------------------------------------------------------------
CORS_ORIGINS=*
# Example for production:
# CORS_ORIGINS=https://mlb-predictor.vercel.app

# ---------------------------------------------------------------------------
# Data Cache
# How many seconds a prediction file is considered fresh before re-running.
# Default: 3600 (1 hour)
# ---------------------------------------------------------------------------
CACHE_EXPIRY_SECONDS=3600

# ---------------------------------------------------------------------------
# Scraper / External Requests
# User-Agent string sent to sports data sources.
# ---------------------------------------------------------------------------
SCRAPER_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/124.0.0.0 Safari/537.36

# ---------------------------------------------------------------------------
# (Future) — Add these when you integrate external paid APIs
# ---------------------------------------------------------------------------
# ODDS_API_KEY=your_the_odds_api_key_here
# DATABASE_URL=postgresql://user:password@host:5432/mlb_db
# SECRET_KEY=your_random_secret_key_here

ODDS_API_KEY=odds_api_key
