# =============================================================================
# MLB Predictor Engine — Frontend Environment Variables (Vite)
#
# HOW TO USE:
#   Local dev : Copy this file → rename to `.env` → fill in your values.
#   Vercel    : Add these as "Environment Variables" in your project settings.
#               Dashboard → Settings → Environment Variables.
#               Do NOT upload the actual .env file.
#
# IMPORTANT: In Vite, only variables prefixed with VITE_ are exposed to the
#            browser bundle. Never put secrets in VITE_ variables.
# =============================================================================

# ---------------------------------------------------------------------------
# Backend API Base URL
# Local dev  : http://localhost:8000/api/v1
# Production : Your Render service URL (no trailing slash)
# ---------------------------------------------------------------------------
VITE_API_URL=http://localhost:8000/api/v1
# Example for production:
# VITE_API_URL=https://mlb-predictor-api.onrender.com/api/v1
